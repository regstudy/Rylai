<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.rylai.app</string>

    <key>CFBundleName</key>
    <string>Rylai</string>

    <key>CFBundleDisplayName</key>
    <string>Rylai</string>

    <key>CFBundleShortVersionString</key>
    <string>1.0.2</string>

    <key>CFBundleVersion</key>
    <string>3</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>

    <!-- Menu bar app: hide Dock icon -->
    <key>LSUIElement</key>
    <true/>

    <key>LSMinimumSystemVersion</key>
    <string>12.0</string>

    <!-- Notification description -->
    <key>NSUserNotificationUsageDescription</key>
    <string>Rylai needs notification permission to alert you when wallpaper is updated.</string>

    <!-- Support automatic dark/light mode switching -->
    <key>NSRequiresAquaSystemAppearance</key>
    <false/>

    <!-- Principal class (SwiftUI App) -->
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
</dict>
</plist>
